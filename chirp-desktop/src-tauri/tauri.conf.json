{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "chirp",
  "version": "1.0.3",
  "identifier": "com.thewh1teagle.chirp",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "chirp",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "assetProtocol": {
        "enable": true,
        "scope": {
          "allow": ["**"],
          "deny": [],
          "requireLiteralLeadingDot": false
        }
      },
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/chirp-runner",
      "binaries/chirp-kokoro-worker"
    ]
  }
}
